# Line-ending policy.
#
# Store every text file with LF in the repository and check it out with LF on
# every platform (including Windows), overriding each machine's core.autocrlf.
# Without this, Windows rewrites the whole tree to CRLF on checkout, so `git
# status` shows every file modified and the mixed-line-ending pre-commit hook
# (configured with --fix=lf) keeps fighting the checkout. `text=auto` lets Git
# auto-detect which files are text.
* text=auto eol=lf

# The Gradle wrapper Unix script must stay LF and executable.
gradlew text eol=lf

# Windows batch scripts only work reliably with CRLF.
*.bat text eol=crlf

# Binary assets Git must never convert or diff.
*.jar binary
*.keystore binary
*.jks binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
